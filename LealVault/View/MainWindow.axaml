<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="LealVault.View.MainWindow"
        Title="LealVault">
	<Grid ColumnDefinitions="Auto, *">
		<StackPanel
			Grid.Column="0"
			Background="#22000000"
			Name="LeftPanel">
			<TextBlock
				Grid.Column="0"
				Text="LealVault"
				Margin="10"
				VerticalAlignment="Center"
				FontWeight="Bold"/>

			<Separator
				HorizontalAlignment="Stretch"/>
			
			<Button
				x:Name="DashboardButton"
				Content="Dashboard"
				Background="Transparent"
				Margin="5"
				HorizontalAlignment="Stretch"/>
			<Button
				x:Name="RegistersButton"
				Content="Registers"
				Background="Transparent"
				Margin="5"
				HorizontalAlignment="Stretch"/>
			<Button
				x:Name="CardsButton"
				Content="Cards"
				Background="Transparent"
				Margin="5"
				HorizontalAlignment="Stretch"/>
			<Button
				x:Name="ConfigurationButton"
				Content="Configuration"
				Background="Transparent"
				Margin="5"
				HorizontalAlignment="Stretch"/>
		</StackPanel>

		<ContentControl Grid.Column="1" Name="ContentContainer" />
	</Grid>
</Window>
