			 x:Class="LealVault.UI.Pages.Login"
			 x:DataType="vm:LoginViewModel"
			 mc:Ignorable="d"
			 d:DesignWidth="800"
			 d:DesignHeight="450">
	<Border>
		<Grid
			ColumnDefinitions="250, *"
			RowDefinitions="*">
			<StackPanel>
				<TextBlock
						>Test</TextBlock>
			</StackPanel>
		</Grid>
	</Border>
</UserControl>
